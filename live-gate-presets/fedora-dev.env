# fedora-dev live-gate preset — PARSED (never sourced) by live-gate-run.sh's lg_load (host fallback).
# A workload may ship its own `.live-gate` at its repo top to override this (preferred, since it
# auto-tracks the run-contract). Installed to ~/.config/live-gate/fedora-dev.env by setup-user.sh.
#
# fedora-dev's run-contract MINUS public publishes (-p) MINUS real secrets MINUS real volumes:
CAND_FENCE='--cap-add NET_ADMIN --cap-add SYS_ADMIN --device /dev/net/tun --device /dev/fuse --security-opt label=disable'
# The image's real health-cmd (OCI drops the Containerfile HEALTHCHECK, so the gate passes it explicitly):
HEALTH='pgrep -x sshd && pgrep -x tailscaled && test -S /run/user/1000/podman/podman.sock'
# Access-path probe: the sshd door actually answers an SSH banner on :22 (run INSIDE the candidate).
# Load-bearing — stronger than the healthcheck's pgrep (a healthy-but-not-serving image fails here).
CAND_PROBE="timeout 6 bash -c 'exec 3<>/dev/tcp/127.0.0.1/22; read -t 5 -u 3 b; case \"\$b\" in SSH-*) exit 0;; *) exit 1;; esac'"
