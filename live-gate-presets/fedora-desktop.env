# fedora-desktop live-gate contract — HOST FALLBACK preset (new multi-target schema).
# Installed to ~/.config/live-gate/fedora-desktop.env by setup-user.sh and read by live-gate-run.sh
# ONLY when the candidate ships NO top-level `.live-gate` of its own (the in-tree file is preferred,
# since it auto-tracks the run-contract and travels with the PR). Same schema as an in-tree
# `.live-gate` — see validation/LIVE-GATE-HANDOFF.md and live-gate.sample.
#
# CONSUMED SAFELY (PARSED, NOT SOURCED): live-gate-run.sh reads this file line by line and assigns
# each KEY=VALUE with `printf -v` — it NEVER `.`/`source`s it, so nothing here is executed on the
# host. Grammar (enforced by the parser): one `KEY=VALUE` per line; quote values that contain spaces
# or shell characters; single quotes are taken VERBATIM (preferred for HEALTH/PROBE commands — their
# `$( )`, `&&`, `;`, `<`, `>` are inert here and only run later INSIDE the fenced container). No
# `;`-chained multi-assignment lines, no cross-variable references ($OTHER): each key stands alone.
#
# fedora-desktop ships TWO lineages in one repo — they share the harness, the app set, and the SOLE
# web gate (Apache Guacamole on :8443), differing only in the INIT contract + native servers:
#   * xrdp (Containerfile)      — supervised-bash PID 1; XFCE-on-X11 + xrdp.
#   * grd  (Containerfile.grd)  — systemd-PID-1; GNOME-Wayland + GRD.
# Model C builds + gates BOTH as explicit targets (ALL must be GREEN), so a grd PR is built with
# Containerfile.grd under the systemd fence — NOT mis-built against the xrdp Containerfile. (This is
# the explicit-target fix for the prior runtime-lineage-guessing approach.)
#
# Both run.sh / run.sh.grd publish ONE public port (-p ${WEB_PORT}:8443). Each fence below carries
# the lineage's run-contract MINUS that public publish (the gate probes :8443/:3389 on the
# candidate's OWN loopback via `podman exec`; nothing is published to the host) and MINUS the real
# secrets (scratch test values are bind-mounted instead — see SECRET_*). A fence may NOT carry a
# publish flag (-p/--publish/-P): the gate fails closed on one (loopback-only by construction).

LIVE_GATE_TARGETS="xrdp grd"

# ---- xrdp target — Containerfile; run.sh flags MINUS -p, MINUS real secrets/volumes ----
CFILE_xrdp='Containerfile'
FENCE_xrdp='--shm-size=1g --cap-add NET_ADMIN --cap-add SYS_ADMIN --device /dev/net/tun --device /dev/fuse --security-opt label=disable'

# ---- grd target — Containerfile.grd; run.sh.grd flags MINUS -p, MINUS real secrets/volumes. Adds
# the systemd-PID-1 contract (--systemd=always --cgroupns=host -v /sys/fs/cgroup:rw) so a grd
# candidate can ACTUALLY BOOT for Gate B. ----
CFILE_grd='Containerfile.grd'
FENCE_grd='--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --shm-size=1g --cap-add NET_ADMIN --cap-add SYS_ADMIN --device /dev/net/tun --device /dev/fuse --security-opt label=disable'

# ---- scratch secrets — DISPOSABLE test values supplied to the fenced run, NEVER real, NEVER baked.
# The gate writes these to a 0600 file + bind-mounts it read-only at SECRET_MOUNT. Both lineages
# consume /etc/fedora-desktop/secrets.env (xrdp sources it; grd's firstboot oneshot reads it via
# EnvironmentFile), so the same pair is declared for both targets (no cross-references — each key
# stands alone). RDP_PW/GUAC_PW are the entrypoint's fail-fast required pair — set so the candidate
# provisions + serves; the values are throwaway (the gate never logs in, it only asserts the doors
# answer). ----
SECRET_MOUNT_xrdp='/etc/fedora-desktop/secrets.env'
SECRET_ENV_xrdp='RDP_PW=gate-scratch-rdp-not-a-real-secret
GUAC_PW=gate-scratch-guac-not-a-real-secret'
SECRET_MOUNT_grd='/etc/fedora-desktop/secrets.env'
SECRET_ENV_grd='RDP_PW=gate-scratch-rdp-not-a-real-secret
GUAC_PW=gate-scratch-guac-not-a-real-secret'

# ---- resource caps + health budget (per target) — a full desktop (JVM/Tomcat + MariaDB +
# GNOME/XFCE) needs more headroom + a longer first-boot window than the bare-sshd default. One
# KEY=VALUE per line (no `;`-chaining — the parser takes one assignment per line). ----
MEMORY_xrdp='4g'
PIDS_xrdp='2048'
HEALTH_START_xrdp='90s'
HEALTH_TRIES_xrdp='40'
HEALTH_SLEEP_xrdp='6'
MEMORY_grd='4g'
PIDS_grd='2048'
HEALTH_START_grd='90s'
HEALTH_TRIES_grd='40'
HEALTH_SLEEP_grd='6'

# ---- health-cmd (per target; identical paths across lineages) — mirrors run.sh / run.sh.grd (OCI
# drops the Containerfile HEALTHCHECK, so the gate passes it explicitly): the public web door
# returns 200, the loopback RDP backend is open, and the MariaDB auth DB answers a ping. SINGLE-
# QUOTED so the `$( )`/`&&`/`<>` are inert here and only run INSIDE the candidate. ----
HEALTH_xrdp='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && exec 3<>/dev/tcp/127.0.0.1/3389 && mariadb-admin --socket=/var/lib/mysql/mysql.sock ping'
HEALTH_grd='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && exec 3<>/dev/tcp/127.0.0.1/3389 && mariadb-admin --socket=/var/lib/mysql/mysql.sock ping'

# ---- access-path probe (per target; identical) — the "does it actually serve" assertion, run
# INSIDE the candidate via `podman exec` (hits the candidate's OWN loopback — nothing published).
# Stronger than the healthcheck: the PUBLIC web gateway must answer /guacamole/ with HTTP 200 AND
# the loopback RDP :3389 door (the only thing the web gate fronts) must be open. SINGLE-QUOTED. ----
PROBE_xrdp='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && timeout 6 bash -c "exec 3<>/dev/tcp/127.0.0.1/3389"'
PROBE_grd='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && timeout 6 bash -c "exec 3<>/dev/tcp/127.0.0.1/3389"'
